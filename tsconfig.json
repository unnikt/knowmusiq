{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "context/**/*",
    "lib/**/*",
    "next-env.d.ts",
    "server/**/*",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "scripts/writeragas.js"
  ],
  "exclude": [
    "node_modules",
    "packages",
    "scripts",
    "docs",
    "src",
    ".next"
  ]
}